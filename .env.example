# Groq API key — PRIMARY LLM. Get one free at https://console.groq.com/keys
# (No credit card. Fastest inference, 12K TPM on llama-3.3-70b free tier.)
GROQ_API_KEY=

# OpenRouter API key — FALLBACK when Groq rate-limits. https://openrouter.ai/keys
# (No credit card. Used automatically when the primary hits 429.)
OPENROUTER_API_KEY=

# Telegram bot token — from @BotFather: /newbot → pick name → pick @username (must end in "bot")
TELEGRAM_BOT_TOKEN=

# YOUR pincode — grocery prices are hyperlocal. 6 digits, no spaces.
# (Currently informational; platforms default to a guess. Future: pinned location.)
USER_PINCODE=560001

# Optional overrides. Defaults: groq/llama-3.3-70b-versatile + openrouter qwen3-next-80b free
# PRIMARY_MODEL=groq/llama-3.3-70b-versatile
# FALLBACK_MODEL=openrouter/qwen/qwen3-next-80b-a3b-instruct:free
